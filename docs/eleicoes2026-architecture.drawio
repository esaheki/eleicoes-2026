        <mxCell id="e-keywords-api" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-ddb-keywords" target="svc-lambda-api">
          <mxGeometry relative="1" as="geometry" />
