        <!-- Step 9: Lambda -> API GW -->
        <mxCell id="e-api-apigw" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-lambda-api" target="svc-apigw-rest">
