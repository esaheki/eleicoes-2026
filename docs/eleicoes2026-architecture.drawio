        <!-- API GW -> CloudFront; S3 site -> CloudFront; ACM -> CloudFront -->
        <mxCell id="e-rest-cf" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-apigw-rest" target="svc-cloudfront">
