        <mxCell id="e-comments-broadcaster" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-ddb-comments" target="svc-broadcaster">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-election-api" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-ddb-election" target="svc-lambda-api">
