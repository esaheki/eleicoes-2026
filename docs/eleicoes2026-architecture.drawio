        <mxCell id="e-acm-cf" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;dashed=1;fontFamily=Helvetica;" edge="1" parent="1" source="svc-acm" target="svc-cloudfront">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CloudFront -> Route53; Route53 -> Users (Step 10) -->
        <mxCell id="e-cf-r53" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-cloudfront" target="svc-route53">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-r53-users" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-route53" target="users-c">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Archive pipeline -->
        <mxCell id="e-firehose-s3raw" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-firehose" target="svc-s3-raw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s3raw-glue" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-s3-raw" target="svc-glue">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- LEGEND PANEL -->
        <mxCell id="legend-bg" style="verticalLabelPosition=bottom;verticalAlign=top;html=1;shape=mxgraph.basic.rect;fillColor2=none;strokeWidth=1;size=20;indent=5;fillColor=light-dark(#EDF3FF,#305363);strokeColor=#6c8ebf;" value="" vertex="1" parent="1">
          <mxGeometry x="2450" y="20" width="600" height="900" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=18;fontStyle=1;labelBackgroundColor=none;fontFamily=Helvetica;" value="Architecture Steps" vertex="1" parent="1">
          <mxGeometry x="2470" y="30" width="560" height="30" as="geometry" />
        </mxCell>

        <!-- Step legend entries -->
        <mxCell id="ls1-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="1" vertex="1" parent="1">
          <mxGeometry x="2462" y="72" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ls1-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;Collection Scheduling&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;EventBridge triggers Collector Lambdas: 60s for Reddit/NewsAPI, 5min for Apify (Threads, X) and YouTube&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="72" width="530" height="58" as="geometry" />
        </mxCell>

        <mxCell id="ls2-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="2" vertex="1" parent="1">
          <mxGeometry x="2462" y="140" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ls2-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;API Fetch + Deduplication&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Collectors pull posts from Social APIs; DynamoDB seen-ids table (10min TTL) prevents duplicate ingestion&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="140" width="530" height="58" as="geometry" />
        </mxCell>

        <mxCell id="ls3-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="3" vertex="1" parent="1">
          <mxGeometry x="2462" y="208" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ls3-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;Kinesis Data Streams&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Posts published in batches of 500. On-Demand mode auto-scales for election-day traffic spikes&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="208" width="530" height="58" as="geometry" />
        </mxCell>

        <mxCell id="ls4-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="4" vertex="1" parent="1">
          <mxGeometry x="2462" y="276" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ls4-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;Language Filter&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Processor Lambda (batch=100) calls Comprehend DetectDominantLanguage; drops posts with Portuguese confidence below 0.7&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="276" width="530" height="58" as="geometry" />
        </mxCell>

        <mxCell id="ls5-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="5" vertex="1" parent="1">
          <mxGeometry x="2462" y="344" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ls5-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;Sentiment Analysis&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Comprehend DetectSentiment classifies each post as POSITIVE / NEGATIVE / NEUTRAL with a confidence score (PT)&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="344" width="530" height="58" as="geometry" />
        </mxCell>

        <mxCell id="ls6-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="6" vertex="1" parent="1">
          <mxGeometry x="2462" y="412" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ls6-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;Misinformation Scoring&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Bedrock Claude Haiku scores each post 0-100 for likely misinformation and assigns claim flags (concurrency-5 p-limit)&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="412" width="530" height="58" as="geometry" />
        </mxCell>

        <mxCell id="ls7-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="7" vertex="1" parent="1">
          <mxGeometry x="2462" y="480" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ls7-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;DynamoDB Writes + Archive&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Results written to 4 tables (election-sentiment 30h, comment-samples 15min, misinfo-events 30d, keyword-counts 48h). Firehose archives raw stream to S3&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="480" width="530" height="68" as="geometry" />
        </mxCell>

        <mxCell id="ls8-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="8" vertex="1" parent="1">
          <mxGeometry x="2462" y="558" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ls8-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;API + WebSocket Push&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;DDB Streams trigger Broadcaster to push batched score_update and new_sample_batch WS events. API Lambda serves 5 REST endpoints with LGPD author anonymization&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="558" width="530" height="68" as="geometry" />
        </mxCell>

        <mxCell id="ls9-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="9" vertex="1" parent="1">
