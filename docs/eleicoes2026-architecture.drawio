          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s3site-cf" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#545B64;rounded=0;fontFamily=Helvetica;" edge="1" parent="1" source="svc-s3-site" target="svc-cloudfront">
