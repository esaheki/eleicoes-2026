        </mxCell>
        <mxCell id="ls9-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;API Gateway + CloudFront&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;API GW REST fronts Lambda; WS API routes to Broadcaster. CloudFront caches /v1/scores with 30s TTL; ACM certificate covers *.eleicoes-2026.com&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="636" width="530" height="68" as="geometry" />
        </mxCell>

        <mxCell id="ls10-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="10" vertex="1" parent="1">
