        <mxCell id="ls10-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;b&gt;Public Dashboard&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Route 53 routes eleicoes-2026.com to CloudFront. Brazilian voters receive the React SPA from S3 and live sentiment updates via WebSocket&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2510" y="714" width="530" height="68" as="geometry" />
